apiVersion: apps/v1
kind: Deployment
metadata:
  name: javawebdeplmnt
  namespace: prod
spec:
  replicas: 1
  strategy:
    type: RollingUpdate
    rollingUpdate:
      maxUnavailable: 1
      maxSurge: 1
  selector:
    matchLabels:
      app: javwebappdep
  template:
    metadata:
      name: amazonfreshpod
      labels:
        app: javwebappdep
    spec:
      containers:
      - name: amazon-cont1
        image: nandu90199/train0
        resources:
          requests:
            memory: "20Mi"
            cpu: "32m"
          limits:
            memory: "50Mi"
            cpu: "64m"
        ports:
        - containerPort: 80
---
apiVersion: v1
kind: Service
metadata:
  name: javawebappsvc
  namespace: prod
spec:
  type: NodePort
  selector:
    app: javwebappdep
  ports:
  - port: 80
    targetPort: 80
    nodePort: 31255

